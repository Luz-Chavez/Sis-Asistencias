# Configuración de Base de Datos
DATABASE_URL=postgresql://postgres:admin@localhost:5432/sis_asistencias

# Configuración de Correo SMTP (OBLIGATORIO PARA NOTIFICACIONES)
# Usar Gmail como ejemplo
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion
SMTP_FROM=tu_correo@gmail.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Configuración de Correo Secundario (Opcional - backup)
# SMTP2_HOST=smtp.outlook.com
# SMTP2_PORT=587
# SMTP2_USER=tu_correo@outlook.com
# SMTP2_PASS=tu_contraseña
# SMTP2_FROM=tu_correo@outlook.com
# SMTP2_USE_TLS=true
# SMTP2_USE_SSL=false

# Configuración de JWT
SECRET_KEY=tu_secreto_jwt_muy_seguro_aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Configuración de Aplicación
DEBUG=true
ENVIRONMENT=development
